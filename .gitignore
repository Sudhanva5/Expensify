# ============================================================
# Node / TypeScript (root + cloudflare-worker)
# ============================================================
node_modules/
dist/
build/
.tsbuildinfo
*.tsbuildinfo
coverage/
.npm
.pnpm-store/
npm-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
*.tgz

# ============================================================
# Environment files & secrets
# ============================================================
# Real env stays out — only .env.example (if added) should ever be committed.
.env
.env.local
.env.*.local
.env.production
.env.development
# APNs auth key (PEM/P8) and Google OAuth credentials should NEVER be
# checked in — every secret lives in Railway env vars instead.
*.p8
*.p12
*.pem
*.key
credentials.json
*credentials*.json
service-account*.json

# ============================================================
# Prisma
# ============================================================
# Local SQLite dev databases (we use Postgres on Railway, but Prisma
# may generate these during `prisma migrate dev` if a connection
# probe fails).
prisma/migrations/dev.db*
prisma/.env
# Prisma client is regenerated by `postinstall`; no need to track.
src/generated/

# ============================================================
# Xcode / SwiftUI (Expensify/)
# ============================================================
# Per-user IDE state. Never commit — different on every Mac.
xcuserdata/
*.xcuserstate
*.xcuserdatad/
# Build products
build/
DerivedData/
*.xcworkspace/xcuserdata/
*.xcworkspace/xcshareddata/swiftpm/
.swiftpm/
# Archive & symbolication artifacts
*.ipa
*.dSYM
*.dSYM.zip
# Swift Package Manager — keep Package.resolved (deterministic
# builds) but ignore the local resolution cache.
.build/
Packages/
# CocoaPods (not currently used, but defensive)
Pods/
Podfile.lock.bak

# ============================================================
# Cloudflare Worker
# ============================================================
cloudflare-worker/.wrangler/
.wrangler/
# Wrangler local dev state
.dev.vars

# ============================================================
# Editors / IDE state
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
# Claude Code local session state (per-project memory + cache)
.claude/
# Cursor
.cursor/

# ============================================================
# macOS / shell
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

# ============================================================
# Scratch / one-off scripts (live in /tmp during dev)
# ============================================================
*.bak
*.orig
scratch/
tmp/
