DATABASE_URL="postgresql://expense:expense@localhost:5432/expense_solver?schema=public"

GROQ_API_KEY=
BRAVE_SEARCH_API_KEY=
EXCHANGERATE_API_KEY=

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_PUBSUB_TOPIC=projects/PROJECT_ID/topics/gmail-inbound
GOOGLE_PUBSUB_VERIFICATION_AUDIENCE=

APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=com.sudhanva.Expensify
# Base64-encoded contents of your AuthKey_XXX.p8 file. To generate locally:
#   base64 -i AuthKey_XXX.p8 | tr -d '\n' | pbcopy
APNS_KEY_CONTENT=
# Set to "true" while testing with a debug build of the iOS app, leave empty
# (or "false") for production / TestFlight / App Store builds.
APNS_USE_SANDBOX=true

# Static auth token shared between iOS and backend.
# Generate with: openssl rand -hex 32
API_TOKEN=

REDIS_URL=redis://localhost:6379
