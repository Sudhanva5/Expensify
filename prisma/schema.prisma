// Expense Solver — V1 schema
// See CLAUDE.md for the design behind these tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Transactions
// ============================================================

model Transaction {
  id String @id @default(cuid())

  // Money — stored in minor units (paise for INR, cents for USD/EUR) as BigInt to avoid float drift
  amountMinor       BigInt
  currency          String   @default("INR")
  amountInrMinor    BigInt?
  bankConvertedRate Decimal? @db.Decimal(12, 6)
  marketRate        Decimal? @db.Decimal(12, 6)
  fxMarkupPct       Decimal? @db.Decimal(6, 3)

  // What & when
  merchantRaw        String
  merchantNormalized String
  vpa                String?
  occurredAt         DateTime
  direction          Direction
  instrument         String

  // Source & idempotency
  gmailMessageId String   @unique
  emailTemplate  String
  parserVersion  String
  rawSubject     String
  rawSnippet     String

  // Location
  locationLat    Decimal?       @db.Decimal(10, 7)
  locationLng    Decimal?       @db.Decimal(10, 7)
  locationStatus LocationStatus @default(awaiting)

  // Categorization
  category      Category? @relation(fields: [categoryId], references: [id])
  categoryId    String?
  confidence    Decimal?  @db.Decimal(4, 3)
  signalSource  String?
  matchedRuleId String?
  status        TxStatus  @default(awaiting_location)
  autoFinalized Boolean   @default(false)

  /// Top-N nearby Places candidates from the recategorize pass, kept
  /// even when ambiguity or low confidence prevented an auto-tag. iOS
  /// surfaces these as "Nearby places" suggestions the user can tap to
  /// claim one. Shape: `[{ name, category, distanceM, lat, lng }, ...]`.
  placesSuggestions Json?

  tags     TransactionTag[]
  receipts EmailReceipt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([occurredAt])
  @@index([categoryId, occurredAt])
  @@index([merchantNormalized])
  @@index([status])
}

enum Direction {
  in
  out
}

enum LocationStatus {
  awaiting
  fulfilled
  missed
  not_applicable
}

enum TxStatus {
  awaiting_location
  pending_review
  resolved
}

// ============================================================
// Categories & Tags
// ============================================================

model Category {
  id           String            @id @default(cuid())
  name         String            @unique
  parentId     String?
  parent       Category?         @relation("CategoryParent", fields: [parentId], references: [id])
  children     Category[]        @relation("CategoryParent")
  transactions Transaction[]
  budgets      Budget[]
  patterns     MerchantPattern[]
  vpaPatterns  VpaPattern[]
  rules        UserRule[]
  aliases      MerchantAlias[]
}

model Tag {
  id           String           @id @default(cuid())
  name         String           @unique
  transactions TransactionTag[]
}

model TransactionTag {
  transactionId String
  tagId         String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
}

// ============================================================
// Merchant resolution
// ============================================================

model MerchantAlias {
  id         String    @id @default(cuid())
  rawPattern String    @unique
  canonical  String
  category   Category? @relation(fields: [categoryId], references: [id])
  categoryId String?
  matchType  String    @default("exact") // "exact" | "substring" | "regex"
  notes      String?
}

model MerchantPattern {
  id                 String   @id @default(cuid())
  merchantNormalized String   @unique
  category           Category @relation(fields: [categoryId], references: [id])
  categoryId         String
  hitCount           Int      @default(1)
  autoTagActive      Boolean  @default(false)
  firstSeenAt        DateTime @default(now())
  lastConfirmedAt    DateTime @default(now())
}

/// VPA-keyed pattern. Single hit is enough to flip autoTagActive — UPI
/// VPAs are unique-per-shop (much more so than merchant names), so the
/// user's single confirmation that "this VPA → this category" is high
/// signal. Future transactions with the same VPA auto-tag immediately,
/// AND a bulk update sweeps existing transactions with that VPA to the
/// new category at confirmation time. Beats the 3-hit MerchantPattern
/// for VPAs we recognize.
model VpaPattern {
  id              String   @id @default(cuid())
  vpa             String   @unique
  category        Category @relation(fields: [categoryId], references: [id])
  categoryId      String
  hitCount        Int      @default(1)
  firstSeenAt     DateTime @default(now())
  lastConfirmedAt DateTime @default(now())
  /// Display name to apply to future transactions on this VPA. Populated
  /// when the user claims a Places suggestion via /transactions/:id/apply-place.
  /// Null when the only confirmation source was a category PATCH without
  /// a Places resolution (the bank's raw payee stays in that case).
  merchantName    String?
}

// ============================================================
// User rule engine
// ============================================================

model UserRule {
  id                String   @id @default(cuid())
  name              String
  priority          Int      @default(100)
  enabled           Boolean  @default(true)
  conditions        Json
  category          Category @relation(fields: [categoryId], references: [id])
  categoryId        String
  defaultConfidence Decimal  @default(0.6) @db.Decimal(4, 3)
  hitCount          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================================
// Budgets & alerts
// ============================================================

model Budget {
  id              String             @id @default(cuid())
  category        Category           @relation(fields: [categoryId], references: [id])
  categoryId      String             @unique
  monthlyLimitInr BigInt
  alertThresholds Decimal[]          @db.Decimal(4, 3)
  enabled         Boolean            @default(true)
  alerts          BudgetAlertFired[]
}

model BudgetAlertFired {
  id        String   @id @default(cuid())
  budget    Budget   @relation(fields: [budgetId], references: [id])
  budgetId  String
  yearMonth String
  threshold Decimal  @db.Decimal(4, 3)
  firedAt   DateTime @default(now())

  @@unique([budgetId, yearMonth, threshold])
}

// ============================================================
// Goals
// ============================================================

model Goal {
  id              String   @id @default(cuid())
  name            String
  targetAmountInr BigInt
  deadline        DateTime
  createdAt       DateTime @default(now())
}

// ============================================================
// System / health
// ============================================================

model GmailOauth {
  id             String    @id @default(cuid())
  refreshToken   String
  watchExpiresAt DateTime?
  lastHistoryId  String?
  updatedAt      DateTime  @updatedAt
}

model DeviceToken {
  id        String   @id @default(cuid())
  apnsToken String   @unique
  lastSeen  DateTime @default(now())
}

model FxRate {
  id       String   @id @default(cuid())
  date     DateTime @db.Date
  currency String
  rateInr  Decimal  @db.Decimal(12, 6)

  @@unique([date, currency])
}

model ParserHealth {
  id                String   @id @default(cuid())
  template          String   @unique
  lastParsedAt      DateTime
  lastParserVersion String
}

model EmailMessage {
  id             String    @id @default(cuid())
  gmailMessageId String    @unique
  kind           String
  parsedAt       DateTime?
  parserVersion  String?
  rawSubject     String
  rawSnippet     String
  rawHeaders     Json?
  parseError     String?
  receivedAt     DateTime  @default(now())
}

// ============================================================
// Receipts (Swiggy / Amazon / Uber / etc.)
// ============================================================
//
// Receipt emails from major online merchants give us much richer context
// than the bank's HDFC alert ("₹308 debited" vs. "Belgian Waffle Co. —
// 1× Triple Chocomelt Waffle ₹185 + Restaurant Packaging ₹10 + ..."). We
// capture them in a parallel pipeline and bind them to HDFC transactions
// by amount + timestamp.
//
// `transactionId` is nullable — receipts may arrive before the HDFC alert
// or fail to match (orphan). The iOS app surfaces them via the bottom-
// sheet "more details" card.
//
// `itemsJson` / `feesJson` / `metaJson` are loose to accommodate per-
// merchant parser output without rigid schema migrations every time we
// add a new merchant. Each parser version stamps `parserVersion` so we
// can re-run extraction if formats change.

model EmailReceipt {
  id             String   @id @default(cuid())
  gmailMessageId String   @unique
  source         String   // 'swiggy', 'amazon', 'zomato', 'bookmyshow', 'uber', 'generic'
  subject        String
  snippet        String   // Gmail's first ~200 chars preview
  receivedAt     DateTime
  fromAddress    String?

  // Lightweight extracts that work across every merchant via universal regex.
  amountInrMinor BigInt?
  orderId        String?

  // Optional rich extraction (per-merchant parsers). Null when only
  // the universal regex fired or the merchant parser failed.
  itemsJson      Json?    // [{ name, qty, price (rupees) }]
  feesJson       Json?    // [{ name, amount (rupees) }]
  metaJson       Json?    // { fromAddress, toAddress, restaurant, etas, etc. }

  parserVersion  String   // 'swiggy.v1', 'generic.v1', etc.
  parseError     String?

  // Optional bind to an HDFC transaction (amount + timestamp match).
  // Nullable because:
  //   - receipt may arrive before the HDFC alert (race)
  //   - amount + timestamp may not match anything (orphan)
  //   - user may have multiple cards and we couldn't disambiguate
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  transactionId String?

  createdAt DateTime @default(now())

  @@index([transactionId])
  @@index([receivedAt])
  @@index([source, receivedAt])
}

// ============================================================
// Google Contacts cache
// ============================================================

// ============================================================
// MCP OAuth (claude.ai web custom connector flow)
// ============================================================
//
// The MCP server is also reachable by direct static-bearer (MCP_TOKEN env)
// — that's how Claude Code and Claude Desktop connect. claude.ai web's
// custom-connector flow REQUIRES OAuth 2.1 with PKCE + dynamic client
// registration; these three tables back that flow.
//
// Single-user model: the "user" is the holder of the static MCP_TOKEN,
// which acts as the password on the consent screen. Every Claude client
// that completes the OAuth dance gets its own short-lived auth code and
// its own opaque access token, both rooted in McpOAuthClient.
//
// Access tokens are stored as sha256 hashes — the raw value is shown to
// the client exactly once at /token exchange and never again. iOS can
// revoke a token (sets revokedAt), but cannot recover the raw value.

model McpOAuthClient {
  /// We hand this id out to the client at /register; it travels in every
  /// /authorize and /token call. Random 16-byte hex, not a cuid, because
  /// some OAuth clients balk at non-hex client_ids.
  id                      String   @id
  clientName              String?
  /// `client_name` (OAuth 2.0 dynamic client metadata, RFC 7591). We mirror
  /// the field name so /register can echo it back verbatim.
  redirectUris            String[]
  grantTypes              String[]
  responseTypes           String[]
  /// Always "none" in our V1 — Claude clients are public clients using PKCE,
  /// no client secret. Kept on the row for future expansion.
  tokenEndpointAuthMethod String   @default("none")
  scope                   String?
  /// Original /register body, kept verbatim for debugging + audit. Future
  /// optional metadata fields go here without a schema migration.
  metadata                Json
  createdAt               DateTime @default(now())
  lastUsedAt              DateTime?

  authCodes               McpAuthCode[]
  accessTokens            McpAccessToken[]

  @@index([createdAt])
}

model McpAuthCode {
  /// The authorization code itself. Single-use; we set `consumed=true`
  /// the moment /token exchange happens. Indexed (PK) for the O(1)
  /// lookup by code value.
  code                String         @id
  client              McpOAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId            String
  redirectUri         String
  /// PKCE code challenge from /authorize. We only support S256 (the
  /// only method MCP clients use; RFC 8252 also recommends S256).
  codeChallenge       String
  codeChallengeMethod String         @default("S256")
  scope               String?
  expiresAt           DateTime
  consumed            Boolean        @default(false)
  createdAt           DateTime       @default(now())

  @@index([clientId])
  @@index([expiresAt])
}

model McpAccessToken {
  id          String         @id @default(cuid())
  /// sha256(rawToken) in hex. The raw token is shown to the client exactly
  /// once at /token exchange and never persisted. Lookup on /mcp requests
  /// re-hashes the bearer and matches against this column.
  tokenHash   String         @unique
  client      McpOAuthClient @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId    String
  scope       String?
  /// Human-readable name surfaced in the iOS Diagnostics UI. Derived from
  /// the client's `client_name` at issuance, frozen so revocation lists
  /// don't mutate if the client later re-registers with a new name.
  label       String?
  issuedAt    DateTime       @default(now())
  /// Optional expiry. Null means "never expires" — fine for a single-user
  /// app where the iOS revoke button is the lifecycle control.
  expiresAt   DateTime?
  /// Bumped on every successful /mcp call; nullable until first use.
  lastUsedAt  DateTime?
  /// Set when iOS clicks "revoke". /mcp auth check treats any row with
  /// revokedAt != null as invalid.
  revokedAt   DateTime?

  @@index([clientId])
  @@index([revokedAt])
}

/// Snapshot of the authenticated user's Google contacts, populated by
/// the People API sync script. Used to attach a "who am I paying"
/// photo on P2P UPI rows even when the iOS address book doesn't have
/// the same contact (e.g., contact stored only in Google account).
///
/// Single-user V1 — no userId column. A re-sync overwrites the table
/// rather than diffing, so resourceName is the natural key only inside
/// a single sync run.
model GoogleContact {
  id           String   @id @default(cuid())
  resourceName String   @unique
  displayName  String?
  givenName    String?
  familyName   String?
  /// Phone numbers normalized to digits-only (no +91, no spaces, no dashes).
  /// Lets the VPA-lookup match "9876543210@ybl" against the contact whose
  /// stored number is "+91 98765 43210".
  phoneDigits  String[]
  /// Raw E.164-ish numbers (kept for debugging / display only).
  phonesRaw    String[]
  emails       String[]
  /// People API photo URL. Public-ish but lifetime-bounded — fetch + cache
  /// the bytes on the client. Empty string when the contact has no photo.
  photoUrl     String?
  syncedAt     DateTime @default(now())

  @@index([syncedAt])
}
